{
  "name": "caching-proxy",
  "version": "1.0.0",
  "description": "A caching proxy server built with NestJS",
  "main": "dist/main.js",
  "bin": {
    "caching-proxy": "./dist/cli.js"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:dev": "tsc -p tsconfig.build.json --watch",
    "cli": "node dist/cli.js",
    "test": "chmod +x test.sh && ./test.sh",
    "setup": "npm install && npm run build",
    "clean": "rm -rf dist node_modules .cache"
  },
  "keywords": ["caching", "proxy", "server", "nestjs"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "axios": "^1.6.0",
    "commander": "^11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  }
}